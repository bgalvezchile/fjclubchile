# Copia este archivo a .env.local y completa los valores reales.
# En Vercel: Project Settings → Environment Variables.

# API key de Resend (resend.com) — para enviar los emails del formulario de contacto.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email donde quieres recibir los mensajes del formulario de contacto.
CONTACT_EMAIL_TO=contacto@fjclubchile.cl

# Email donde quieres recibir las inscripciones de la 5ª Ruta.
INSCRIPCION_EMAIL_TO=bgalvez@gmail.com
